# Client environment template — skopíruj na client/.env a vyplň.
# Vite premenné MUSIA mať prefix VITE_, inak ich Vite nezachytí.

# API base URL. V dev nechaj prázdne (Vite proxy forwarduje /api/* na :3001).
# V prod nastav plnú URL Render backendu, napr. https://api.pawly.sk
VITE_API_URL=

# Firebase Web App SDK config — z Firebase Console → Project Settings → Your apps → Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
