# Server konfigurácia
PORT=3001
NODE_ENV=development

# OpenAI / Google Vision
OPENAI_API_KEY=
GOOGLE_VISION_API_KEY=

# CORS (comma-separated, odporúčané v produkcii)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Firebase Admin (Service Account) — povinné pre autentifikáciu API
# Z Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Celý privátny kľúč na jednom riadku, novelines ako \n (v úvodzovkách)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
