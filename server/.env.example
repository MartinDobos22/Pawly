# Server environment template — skopíruj na server/.env a vyplň.
# NIKDY necommituj reálne hodnoty.

PORT=3001
NODE_ENV=development

# OpenAI — analýza krmiva, AI sumáre, interpretácia zdravotnej karty.
OPENAI_API_KEY=

# Google Vision API — OCR.
GOOGLE_VISION_API_KEY=

# CORS allowlist (comma-separated, bez koncového /).
# Pre lokálny dev stačí default; v prod nastav Netlify/produkčný frontend host.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Firebase Admin (Service Account). FIREBASE_PRIVATE_KEY musí mať novelines
# ako \n v úvodzovkách — config/firebase.ts ich nahradí reálnymi.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""

# Supabase — DB a privátne storage.
#
# !!! BEZPEČNOSTNÉ UPOZORNENIE !!!
# SUPABASE_SERVICE_ROLE_KEY obchádza Row Level Security. Pre lokálny dev
# si VYTVOR SAMOSTATNÝ Supabase projekt (napr. "animalpassport-dev") a
# použi jeho kľúče. Produkčný service_role kľúč drž výhradne v Render
# (alebo inom prod hosting) dashboarde — nikdy v lokálnom .env.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cron endpoint (POST /api/cron/*) auth — shared secret porovnaný timing-safe.
CRON_SHARED_SECRET=

# AI model overrides (voliteľné). Default hodnoty sú v server/src/services/aiService.ts (MODELS).
# Slúžia na A/B testing kvality vs ceny bez code change. Nechaj prázdne pre default.
MODEL_OCR_NORMALIZE=
MODEL_OCR_VISION=
MODEL_DOC_CONTEXT=
MODEL_EXAM_ANALYSIS=
MODEL_VET_FILE=
MODEL_PASSPORT_INTERPRET=
MODEL_EPISODE_SUMMARY=
MODEL_FOOD_SAFETY=
MODEL_FEED_ANALYSIS=
